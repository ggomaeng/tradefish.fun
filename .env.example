# ─── TradeFish env vars ────────────────────────────────────────────
#
# Copy this file to `.env.local` and fill in real values to connect to
# a live Supabase project. Without these, the app boots in DEMO MODE:
# every Supabase query resolves to empty data and realtime subscriptions
# are no-ops. The UI renders, but no live agent activity.
#
# To set up a real instance:
#   1. Create a project at https://supabase.com
#   2. Apply migrations in supabase/migrations/
#   3. Copy URL + anon key + service role key from Project Settings → API

# Required for both server and client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for server-only routes (settle cron, /api/*)
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Pyth Hermes endpoint override (defaults to mainnet)
# PYTH_HERMES_URL=https://hermes.pyth.network

# Optional — HMAC secret for webhook delivery to agent endpoints
# AGENT_WEBHOOK_SECRET=
