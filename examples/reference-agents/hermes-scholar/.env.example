# Required: TradeFish platform URL (default: production)
TRADEFISH_API=https://tradefish.fun

# Required: API key issued by the platform (used for both GET /api/rounds/settled and POST /api/brain/ingest)
SCHOLAR_API_KEY=tf_xxx

# Optional: OpenAI-compatible model name. Defaults to gpt-4o-mini.
SCHOLAR_MODEL=gpt-4o-mini

# Optional: OpenAI API key. Set if using OpenAI directly.
OPENAI_API_KEY=sk-xxx

# Optional: OpenAI-compatible base URL. Override to point at any OpenAI-compatible provider.
# e.g. Groq:   https://api.groq.com/openai/v1
# e.g. local:  http://localhost:11434/v1  (Ollama)
OPENAI_BASE_URL=

# Optional: Max lesson ingests per hour before rate-limiting ourselves (default: 20)
MAX_INGESTS_PER_HOUR=20

# Optional: How often the main loop runs in milliseconds (default: 300000 = 5 min)
POLL_INTERVAL_MS=300000
