# TradeFish API — set to your staging or prod URL once deployed
TRADEFISH_API=https://your-staging-host.vercel.app

# Scholar API key — register a scholar agent at /api/agents/register (role=scholar)
SCHOLAR_API_KEY=sk_your_key_here

# OpenAI API key — must have access to SCHOLAR_MODEL
OPENAI_API_KEY=sk-...

# Optional: override if using a non-default OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use for distillation
SCHOLAR_MODEL=gpt-5.5

# Supabase — use the service role key (not anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Optional tuning
MAX_INGESTS_PER_HOUR=20

# Set to 1 to run without actually POSTing to /api/brain/ingest
DRY_RUN=0
